#!/bin/sh
# WCS4: przed commitem zwiększ wersję w VERSION i w wcs.php

set -e
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

VERSION_FILE="VERSION"
MAIN_FILE="wcs.php"

[ ! -f "$VERSION_FILE" ] && echo "Brak pliku $VERSION_FILE" && exit 1
[ ! -f "$MAIN_FILE" ] && echo "Brak pliku $MAIN_FILE" && exit 1

case $(uname) in
Darwin) SED_INPLACE="sed -i ''" ;;
*) SED_INPLACE="sed -i" ;;
esac

# Odczytaj wersję (format: major.minor.patch, np. 4.59.0)
CURRENT=$(cat "$VERSION_FILE" | tr -d '\n\r ')
# Zwiększ patch (ostatni segment)
NEW_VERSION=$(echo "$CURRENT" | awk -F. '{
  if (NF >= 3) { $3 = $3 + 1; print $1"."$2"."$3 }
  else if (NF == 2) { print $1"."$2".1" }
  else { print $1".0.1" }
}')

echo "$NEW_VERSION" >"$VERSION_FILE"

# Aktualizuj nagłówek wersji w wcs.php (linia Version: X.Y.Z)
$SED_INPLACE "s/^Version: .*$/Version: $NEW_VERSION/" "$MAIN_FILE"

# Aktualizuj define('WCS4_VERSION', ...) w bloku else (produkcja) – tylko wersja, bez time()
$SED_INPLACE "s/define('WCS4_VERSION', '[^']*' \\. time());/define('WCS4_VERSION', '$NEW_VERSION');/" "$MAIN_FILE"
$SED_INPLACE "s/define('WCS4_VERSION', '[^']*');/define('WCS4_VERSION', '$NEW_VERSION');/" "$MAIN_FILE"

# Dodaj zmienione pliki do commita
git add "$VERSION_FILE" "$MAIN_FILE"

echo "Wersja ustawiona na: $NEW_VERSION (było: $CURRENT)"
exit 0
